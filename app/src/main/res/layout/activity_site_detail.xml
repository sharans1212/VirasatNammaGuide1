<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/siteName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textSize="28sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/siteImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"
            android:background="@color/stone"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/siteId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:textColor="@color/leaf"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/locationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/location"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:text="@string/town"
                    android:textColor="@color/deep_indigo"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/locationTown"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/ink" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:text="@string/district"
                    android:textColor="@color/deep_indigo"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/locationDistrict"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/ink" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:text="@string/state"
                    android:textColor="@color/deep_indigo"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/locationState"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/ink" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pin_code"
                    android:textColor="@color/deep_indigo"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/locationPincode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/ink" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:text="@string/maps_address"
                    android:textColor="@color/deep_indigo"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/locationMapAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/ink" />
            </LinearLayout>
        </LinearLayout>

        <RadioGroup
            android:id="@+id/languageGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/englishOption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/english" />

            <RadioButton
                android:id="@+id/kannadaOption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="@string/kannada" />
        </RadioGroup>

        <TextView
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="@color/deep_indigo"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/architecture"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/architecture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="@color/deep_indigo"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/legend"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/legend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="@color/deep_indigo"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/hidden_fact"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hiddenFact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:textColor="@color/deep_indigo"
            android:textSize="15sp" />

        <Button
            android:id="@+id/audioButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button"
            android:text="@string/play_audio"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/checkInButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button"
            android:text="@string/check_in"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>
